<!DOCTYPE html>
<html>
<head>
    <title>System Update</title>
    <style>
        body { margin: 0; overflow: hidden; background-color: black; color: white; text-align: center; font-family: sans-serif; }
        img { position: absolute; width: 150px; }
        h1 { margin-top: 20vh; font-size: 3em; }
    </style>
</head>
<body>
    <h1>SYSTEM INFECTED<br>SUCH VIRUS<br>MANY DOGE</h1>
    <script>
        function createDoge() {
            var doge = document.createElement("img");
            // Doge image URL
            doge.src = "https://doge2048.com";
            
            // Random position
            doge.style.left = Math.random() * window.innerWidth + "px";
            doge.style.top = Math.random() * window.innerHeight + "px";
            
            document.body.appendChild(doge);
        }
        
        // Add a new doge every 20 milliseconds (20ms = 20 per second)
        setInterval(createDoge, 20);
    </script>
</body>
</html>
